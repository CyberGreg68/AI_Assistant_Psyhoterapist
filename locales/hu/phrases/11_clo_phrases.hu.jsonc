        "age": [
          "adult",
          "senior"
        ]
      },
      {
        "txt": "Fontos: ha úgy érzed, azonnali veszély áll fenn, kérlek, azonnal keresd a segélyhívót.",
        "t": "f",
        "l": "s",
        "reg": "plain",
        "lit": "low",
        "age": [
          "adult",
          "senior"
        ]
      },
      {
        "txt": "Ha veszélyben vagy, ne várj; azonnal fordulj a helyi segélyszolgálathoz vagy kérj segítséget a környezetedtől.",
        "t": "n",
        "l": "m",
        "reg": "plain",
