    ],
    "tags": [
      "clo",
      "next"
    ],
    "pp": [
      {
        "txt": "A következő lépés lehet, hogy kipróbálsz egy kis gyakorlatot, amit megbeszéltünk.",
        "t": "n",
        "l": "s",
        "reg": "plain",
        "lit": "low",
        "age": [
          "teen",
          "adult",
          "senior"
        ]
      },
      {
        "txt": "Javaslom, hogy próbáld ki a megbeszélt apró lépést a következő napokban, és beszámolsz róla legközelebb.",
        "t": "w",
        "l": "m",
        "reg": "plain",
        "lit": "low",
        "age": [
          "teen",
          "adult",
          "senior"
        ]
      },
      {
        "txt": "Egy egyszerű következő lépés lehet, hogy naponta 5 percet szánsz a légzésgyakorlatra; nézzük meg, hogyan hat rád a következő alkalommal.",
        "t": "n",
        "l": "l",
        "reg": "plain",
        "lit": "low",
        "age": [
          "teen",
          "adult",
          "senior"
        ]
      }
    ],
    "reg": "plain",
    "lit": "low",
    "age": [
