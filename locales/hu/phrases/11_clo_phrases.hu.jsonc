        "l": "m",
        "reg": "plain",
        "lit": "low",
        "age": [
          "teen",
          "adult",
          "senior"
        ]
      },
      {
        "txt": "Köszönöm, hogy megosztottad; tartsd szem előtt a kis lépéseket, és találkozunk legközelebb.",
