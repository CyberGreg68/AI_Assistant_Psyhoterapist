    "pp": [
      {
        "txt": "Röviden összefoglalom, amit megbeszéltünk:…",
        "t": "n",
        "l": "s",
        "reg": "plain",
        "lit": "low",
        "age": [
          "teen",
          "adult",
          "senior"
        ]
      },
      {
        "txt": "Összefoglalva: a fő pontok ma ezek voltak…",
        "t": "w",
        "l": "m",
        "reg": "plain",
        "lit": "low",
        "age": [
          "teen",
          "adult",
          "senior"
        ]
      },
      {
        "txt": "Ha röviden összefoglalom a mai beszélgetést: először…, másodszor…, és a következő lépés…",
        "t": "n",
        "l": "l",
        "reg": "plain",
        "lit": "low",
        "age": [
          "teen",
          "adult",
          "senior"
        ]
      }
