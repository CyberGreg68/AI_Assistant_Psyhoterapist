        "l": "m",
        "reg": "plain",
        "lit": "low",
        "age": [
          "teen",
          "adult",
          "senior"
        ]
      },
      {
        "txt": "Ma áttekintettük a fő pontokat, kiválasztottunk egy következő lépést, és megbeszéltük, hogyan követjük nyomon.",
        "t": "w",
        "l": "m",
        "reg": "plain",
        "lit": "low",
        "age": [
          "teen",
          "adult",
          "senior"
        ]
      },
      {
        "txt": "A mai alkalom lényege: meghallgatás, összegzés és egy gyakorlati lépés meghatározása a következő napokra.",
        "t": "n",
        "l": "l",
        "reg": "plain",
        "lit": "low",
        "age": [
          "teen",
          "adult",
          "senior"
        ]
