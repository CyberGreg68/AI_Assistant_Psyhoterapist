    "pp": [
      {
        "txt": "Köszönöm, hogy megosztottad velem ma a gondolataidat.",
        "t": "w",
        "l": "s",
        "reg": "plain",
        "lit": "low",
        "age": [
          "teen",
          "adult",
          "senior"
        ]
      },
      {
        "txt": "Köszönöm, hogy elmondtad, mi foglalkoztat; értékes volt meghallgatni.",
        "t": "n",
        "l": "m",
        "reg": "plain",
        "lit": "low",
        "age": [
          "teen",
          "adult",
          "senior"
        ]
      },
      {
        "txt": "Nagyon köszönöm, hogy megosztottad a történeted; ez segít a továbblépésben.",
        "t": "w",
        "l": "l",
        "reg": "plain",
        "lit": "low",
        "age": [
          "teen",
