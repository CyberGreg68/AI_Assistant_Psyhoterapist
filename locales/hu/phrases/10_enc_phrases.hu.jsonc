    ],
    "tags": [
      "enc",
      "small"
    ],
    "pp": [
      {
        "txt": "Próbálj meg ma egy rövid, kedves dolgot tenni magadért.",
        "t": "n",
        "l": "s",
        "reg": "conversational",
        "lit": "low",
        "age": [
          "teen",
          "adult",
          "senior"
        ]
      },
      {
        "txt": "Egy kis önkényeztetés ma is sokat számít — mit tennél meg magadért?",
        "t": "w",
        "l": "m",
        "reg": "conversational",
        "lit": "low",
        "age": [
          "teen",
          "adult",
          "senior"
        ]
      },
      {
        "txt": "Adj magadnak egy kis figyelmet ma; ez segít feltöltődni és folytatni a munkát.",
        "t": "n",
        "l": "m",
        "reg": "conversational",
        "lit": "low",
        "age": [
          "teen",
          "adult",
          "senior"
        ]
      }
    ],
    "reg": "conversational",
    "lit": "low",
    "age": [
