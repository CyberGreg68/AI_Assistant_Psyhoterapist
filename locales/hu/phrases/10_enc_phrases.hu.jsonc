        "lit": "low",
        "age": [
          "teen",
          "adult",
          "senior"
        ]
      },
      {
        "txt": "Az erőfeszítéseid fontosak; ne becsüld alá, mennyit jelentenek ezek a lépések.",
        "t": "w",
        "l": "l",
        "reg": "conversational",
        "lit": "low",
        "age": [
