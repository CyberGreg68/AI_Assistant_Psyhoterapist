    "tags": [
      "enc",
      "mot"
    ],
    "pp": [
      {
        "txt": "Higgy abban, hogy a változás lehetséges; te is képes vagy rá.",
        "t": "w",
        "l": "s",
        "reg": "conversational",
        "lit": "low",
        "age": [
          "teen",
          "adult",
          "senior"
        ]
      },
      {
        "txt": "A hit a saját képességeidben sokszor elindítja a változást; tartsd meg ezt a hitet.",
        "t": "n",
        "l": "m",
        "reg": "conversational",
        "lit": "low",
        "age": [
          "teen",
          "adult",
          "senior"
        ]
      },
      {
        "txt": "Ha hiszel abban, hogy képes vagy változtatni, az motivációt ad a következő lépésekhez.",
        "t": "w",
        "l": "l",
        "reg": "conversational",
        "lit": "low",
        "age": [
