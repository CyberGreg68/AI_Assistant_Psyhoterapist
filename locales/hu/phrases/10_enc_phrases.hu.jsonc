  {
    "id": "enc_018",
    "pri": 2,
    "rec": [
      "n",
      "w"
    ],
    "use": [
      "c",
      "t"
    ],
    "tags": [
      "enc",
      "emp"
    ],
    "pp": [
      {
        "txt": "Érthető, ha néha elbizonytalanodsz; ez nem von le semmit az erődből.",
        "t": "n",
        "l": "s",
        "reg": "conversational",
        "lit": "low",
        "age": [
          "teen",
          "adult",
          "senior"
        ]
      },
      {
        "txt": "A kételyek természetesek; az, hogy tovább próbálkozol, mutatja az elszántságodat.",
        "t": "w",
        "l": "m",
        "reg": "conversational",
        "lit": "low",
        "age": [
          "teen",
          "adult",
          "senior"
        ]
      },
      {
        "txt": "A kételyek ellenére folytatni a munkát bátorságot és kitartást jelez; ez értékes.",
        "t": "w",
        "l": "l",
        "reg": "conversational",
        "lit": "low",
        "age": [
          "teen",
          "adult",
          "senior"
        ]
      }
    ],
    "reg": "conversational",
    "lit": "low",
    "age": [
      "teen",
      "adult",
      "senior"
    ],
    "meta": {
      "src": "dev",
      "status": "rev",
      "enabled_in": [
        "rt",
