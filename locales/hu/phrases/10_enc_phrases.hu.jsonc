    ],
    "use": [
      "c",
      "t"
    ],
    "tags": [
      "enc",
      "praise"
    ],
    "pp": [
      {
        "txt": "Ma tettél egy lépést; ez már számít.",
        "t": "n",
        "l": "s",
        "reg": "conversational",
        "lit": "low",
        "age": [
          "teen",
          "adult",
          "senior"
        ]
      },
      {
        "txt": "A mai lépésed fontos része a folyamatnak; tartsd meg ezt a lendületet.",
        "t": "w",
        "l": "m",
        "reg": "conversational",
        "lit": "low",
        "age": [
          "teen",
          "adult",
          "senior"
        ]
      },
      {
        "txt": "Minden nap, amikor teszel valamit a célodért, közelebb kerülsz hozzá — ma is megtetted az első lépést.",
        "t": "w",
        "l": "l",
        "reg": "conversational",
        "lit": "low",
        "age": [
          "teen",
          "adult",
          "senior"
        ]
      }
