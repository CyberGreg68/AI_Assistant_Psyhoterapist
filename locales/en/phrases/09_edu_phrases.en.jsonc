        "lit": "low",
        "age": [
          "adult",
          "senior"
        ]
      },
      {
        "txt": "If you experience physical symptoms, it is worth paying attention to your body and your thoughts at the same time when coping.",
        "t": "n",
        "l": "m",
        "reg": "plain",
        "lit": "low",
        "age": [
