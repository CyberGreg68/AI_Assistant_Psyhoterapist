    "pp": [
      {
        "txt": "Slow, deep breathing can help reduce acute anxiety.",
        "t": "n",
        "l": "s",
        "reg": "plain",
        "lit": "low",
        "age": [
          "adult",
          "senior"
        ]
      },
      {
        "txt": "Try 4‑4‑4 breathing: inhale for 4, hold for 4, exhale for 4 seconds.",
        "t": "n",
        "l": "m",
        "reg": "plain",
        "lit": "low",
        "age": [
          "adult",
          "senior"
        ]
      },
      {
        "txt": "Slowing your breathing can quickly lower your heart rate and blood pressure; it is worth practicing several times a day.",
        "t": "w",
        "l": "l",
        "reg": "plain",
        "lit": "low",
        "age": [
          "adult",
          "senior"
        ]
      }
