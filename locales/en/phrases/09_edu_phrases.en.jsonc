      "grounding"
    ],
    "pp": [
      {
        "txt": "A simple grounding technique: list 5 things you see, 4 things you feel, 3 things you hear.",
        "t": "n",
        "l": "m",
        "reg": "plain",
        "lit": "low",
        "age": [
          "adult",
          "senior"
        ]
      },
      {
        "txt": "If the situation upsets you, try the 5‑4‑3‑2‑1 grounding exercise: focusing on the senses helps bring you back to the present.",
        "t": "w",
        "l": "l",
        "reg": "plain",
        "lit": "low",
        "age": [
          "adult",
          "senior"
        ]
      },
      {
        "txt": "Grounding exercises quickly reduce over-activation; they are useful in cases of panic or severe anxiety.",
        "t": "n",
        "l": "m",
        "reg": "plain",
        "lit": "low",
        "age": [
          "adult",
          "senior"
        ]
      }
    ],
