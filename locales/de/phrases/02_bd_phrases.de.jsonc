    "pp": [
      {
        "txt": "Es ist wichtig für Sie zu wissen, dass das, was wir hier besprechen, vertraulich ist, sofern keine Gefahr besteht.",
        "t": "n",
        "l": "s",
        "reg": "plain",
        "lit": "medium",
        "age": [
          "adult",
          "senior"
        ]
      },
      {
        "txt": "Das Gespräch ist vertraulich; Ich muss nur im Gefahrenfall andere benachrichtigen – möchten Sie mehr darüber erfahren?",
        "t": "w",
        "l": "m",
        "reg": "plain",
        "lit": "medium",
        "age": [
          "adult",
          "senior"
        ]
      },
      {
        "txt": "Alles, was Sie teilen, bleibt vertraulich, mit Ausnahme von Sicherheitsausnahmen; Ich freue mich, ausführlicher darüber sprechen zu können.",
        "t": "n",
        "l": "l",
        "reg": "plain",
        "lit": "medium",
        "age": [
          "adult",
          "senior"
        ]
      }
    ],
    "review_required": true,
