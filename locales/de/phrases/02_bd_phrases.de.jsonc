        "l": "m",
        "reg": "plain",
        "lit": "medium",
        "age": [
          "adult",
          "senior"
        ]
      },
      {
        "txt": "Ich helfe Ihnen dabei, Chancen zu erkennen, ersetze jedoch nicht Ihre persönlichen Entscheidungen oder professionellen Rat.",
