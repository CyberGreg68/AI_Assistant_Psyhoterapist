        "l": "l",
        "reg": "plain",
        "lit": "low",
        "age": [
          "adult",
          "senior"
        ]
      },
      {
        "txt": "Wenn bei Ihnen körperliche Symptome auftreten, lohnt es sich, bei der Bewältigung gleichzeitig auf Ihren Körper und Ihre Gedanken zu achten.",
        "t": "n",
        "l": "m",
        "reg": "plain",
        "lit": "low",
