    "pp": [
      {
        "txt": "Kurz gesagt: Reaktionen auf Stress sind völlig normal und Sie können etwas dagegen tun.",
        "t": "n",
        "l": "s",
        "reg": "plain",
        "lit": "low",
        "age": [
          "adult",
          "senior"
        ]
      },
      {
        "txt": "Es ist wichtig zu wissen, dass Reaktionen auf Stress natürlich sind; Es gibt wirksame Bewältigungsmethoden.",
        "t": "w",
        "l": "m",
        "reg": "plain",
        "lit": "low",
        "age": [
          "adult",
          "senior"
        ]
      },
      {
        "txt": "Zusammenfassend lässt sich sagen, dass Stress normal ist und es praktische Maßnahmen gibt, die Sie ergreifen können, um ihn zu reduzieren.",
        "t": "n",
        "l": "m",
        "reg": "plain",
        "lit": "low",
        "age": [
          "adult",
          "senior"
        ]
      }
    ],
    "review_required": true,
