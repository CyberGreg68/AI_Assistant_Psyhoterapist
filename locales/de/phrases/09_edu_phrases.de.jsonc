    "pp": [
      {
        "txt": "Langsames, tiefes Atmen kann helfen, akute Angstzustände zu reduzieren.",
        "t": "n",
        "l": "s",
        "reg": "plain",
        "lit": "low",
        "age": [
          "adult",
          "senior"
        ]
      },
      {
        "txt": "Versuchen Sie es mit der 4-4-4-Atmung: 4 Sekunden lang einatmen, 4 Sekunden lang anhalten, 4 Sekunden lang ausatmen.",
        "t": "n",
        "l": "m",
        "reg": "plain",
        "lit": "low",
        "age": [
          "adult",
          "senior"
        ]
      },
      {
        "txt": "Eine langsamere Atmung kann Ihre Herzfrequenz und Ihren Blutdruck schnell senken; Es lohnt sich, mehrmals täglich zu üben.",
        "t": "w",
        "l": "l",
        "reg": "plain",
        "lit": "low",
        "age": [
          "adult",
          "senior"
        ]
      }
    ],
    "review_required": true,
    "review": {
