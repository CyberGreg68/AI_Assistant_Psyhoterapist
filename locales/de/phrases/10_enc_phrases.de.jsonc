    ],
    "tags": [
      "enc",
      "small"
    ],
    "pp": [
      {
        "txt": "Versuchen Sie heute, etwas Kurzes und Freundliches für sich selbst zu tun.",
        "t": "n",
        "l": "s",
        "reg": "conversational",
        "lit": "low",
        "age": [
          "teen",
          "adult",
          "senior"
        ]
      },
      {
        "txt": "Ein wenig Selbstgefälligkeit zählt auch heute noch viel – was würden Sie für sich tun?",
        "t": "w",
        "l": "m",
        "reg": "conversational",
        "lit": "low",
        "age": [
          "teen",
          "adult",
          "senior"
        ]
      },
      {
        "txt": "Schenken Sie sich heute etwas Aufmerksamkeit; Dies wird Ihnen helfen, neue Energie zu tanken und weiterarbeiten zu können.",
        "t": "n",
        "l": "m",
        "reg": "conversational",
        "lit": "low",
        "age": [
          "teen",
          "adult",
          "senior"
        ]
      }
    ],
    "reg": "conversational",
    "lit": "low",
    "age": [
