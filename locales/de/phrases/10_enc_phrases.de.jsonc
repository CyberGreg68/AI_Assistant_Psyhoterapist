    ],
    "use": [
      "c",
      "t"
    ],
    "tags": [
      "enc",
      "emp"
    ],
    "pp": [
      {
        "txt": "Es ist verständlich, wenn Sie sich manchmal unsicher fühlen; Es nimmt dir nichts von deiner Kraft.",
        "t": "n",
        "l": "s",
        "reg": "conversational",
        "lit": "low",
        "age": [
          "teen",
          "adult",
          "senior"
        ]
      },
      {
        "txt": "Zweifel sind natürlich; Dass du es immer wieder versuchst, zeigt deine Entschlossenheit.",
        "t": "w",
        "l": "m",
        "reg": "conversational",
        "lit": "low",
        "age": [
          "teen",
          "adult",
          "senior"
        ]
      },
      {
        "txt": "Trotz Zweifeln weiterzuarbeiten, zeugt von Mut und Ausdauer; es ist wertvoll.",
        "t": "w",
        "l": "l",
        "reg": "conversational",
        "lit": "low",
        "age": [
          "teen",
          "adult",
          "senior"
        ]
