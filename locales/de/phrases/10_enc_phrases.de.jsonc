      "n"
    ],
    "use": [
      "c",
      "t"
    ],
    "tags": [
      "enc",
      "mot"
    ],
    "pp": [
      {
        "txt": "Denken Sie daran: Beharrlichkeit ist oft wichtiger als schnelle Ergebnisse.",
        "t": "w",
        "l": "s",
        "reg": "conversational",
        "lit": "low",
        "age": [
          "teen",
          "adult",
          "senior"
        ]
      },
      {
        "txt": "Konsequenz und Geduld werden sich auf lange Sicht auszahlen.",
        "t": "n",
        "l": "m",
        "reg": "conversational",
        "lit": "low",
        "age": [
          "teen",
          "adult",
          "senior"
        ]
      },
      {
        "txt": "Bleiben Sie in kleinen Schritten beharrlich; Diese werden im Laufe der Zeit den wirklichen Unterschied machen.",
        "t": "w",
        "l": "l",
        "reg": "conversational",
        "lit": "low",
        "age": [
          "teen",
          "adult",
          "senior"
        ]
      }
    ],
    "reg": "conversational",
    "lit": "low",
    "age": [
